classDiagram
class Reserva {
  +inicio: datetime
  +fin: datetime
  +precioTotal: decimal
  +estado: string
  +paymentDeadline: datetime
  +confirmar()
  +modificar()
  +cancelar()
}

class Pago {
  +importe: decimal
  +metodo: string
  +estado: string
  +numeroRecibo: string
  +registrarPago()
  +marcarReembolsado()
}

class Factura {
  +numeroFactura: string
  +tipoFactura: string
  +total: decimal
  +estado: string
  +esReversion: boolean
  +generar()
  +revertir()
}

class DatosFacturacion {
  +razonSocial: string
  +nifCif: string
  +direccion: string
  +pais: string
  +esPredeterminado: boolean
}

