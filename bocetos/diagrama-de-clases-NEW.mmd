erDiagram
    USERS {
        int user_id PK
        string username
        string email
    }

    PRO_PROFILES {
        int pro_profile_id PK
        int user_id FK
        string display_name
        string status
    }

    SERVICES {
        int service_id PK
        int pro_profile_id FK
        string service_name
        int duration_min
        decimal base_price
        decimal tax_rate
        boolean tax_exempt
    }

    SCHEDULES {
        int schedule_id PK
        int pro_profile_id FK
        int weekday
        time start_time
        time end_time
    }

    BOOKINGS {
        int booking_id PK
        int client_user_id FK
        int pro_profile_id FK
        int service_id FK
        datetime booking_start
        datetime booking_end
        decimal price_total
        string status
        datetime payment_deadline
    }

    PAYMENTS {
        int payment_id PK
        int booking_id FK
        int invoice_id FK
        decimal amount
        string payment_method
        string status
        string receipt_number
    }

    INVOICES {
        int invoice_id PK
        int booking_id FK
        int billing_detail_id FK
        string invoice_type
        decimal total_amount
        string status
        boolean is_reversal
        int reverses_invoice_id FK
        int replaces_invoice_id FK
    }

    BILLING_DETAILS {
        int billing_detail_id PK
        int user_id FK
        string legal_name
        string tax_id
        string country_code
    }

    USERS ||--o| PRO_PROFILES : tiene
    USERS ||--o{ BILLING_DETAILS : tiene
    USERS ||--o{ BOOKINGS : realiza

    PRO_PROFILES ||--o{ SERVICES : ofrece
    PRO_PROFILES ||--o{ SCHEDULES : define
    PRO_PROFILES ||--o{ BOOKINGS : recibe

    SERVICES ||--o{ BOOKINGS : se_reserva_en

    BOOKINGS ||--o{ PAYMENTS : tiene
    BOOKINGS ||--o{ INVOICES : tiene

    PAYMENTS }o--o| INVOICES : se_vincula_con

    BILLING_DETAILS ||--o{ INVOICES : se_usa_en

    INVOICES ||--o| INVOICES : revierte
    INVOICES ||--o| INVOICES : reemplaza
